# =============================================================
# Koyn — Backend Flask — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# =============================================================

# -------------------------------------------------------------
# Banco de Dados (MySQL 8)
# -------------------------------------------------------------
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_HOST=127.0.0.1
DB_NAME=tcc_db

# -------------------------------------------------------------
# Segurança / Autenticação
# -------------------------------------------------------------
# Chave secreta para assinar tokens JWT (gere com: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=sua_jwt_secret_key_aqui

# Chave AES para criptografia (gere com: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())")
AES_ENCRYPTION_KEY=sua_aes_key_aqui

# -------------------------------------------------------------
# Blockchain — Sepolia via Alchemy
# -------------------------------------------------------------
# URL RPC da Alchemy (crie uma app em https://dashboard.alchemy.com)
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/sua_api_key_aqui

# Chave privada da carteira da PLATAFORMA (usada para chamar createEvent no contrato)
# ATENÇÃO: esta carteira precisa ter Sepolia ETH para pagar gas
# Nunca use sua carteira pessoal principal aqui
BLOCKCHAIN_PRIVATE_KEY=0xsua_chave_privada_aqui
